# Server
PORT=4000

# MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/structunex

# Python calc microservice
CALC_SERVICE_URL=http://localhost:8000

# CORS: frontend origin(s). Acepta una lista separada por comas.
# En producción por defecto usa https://structunex.com,https://www.structunex.com
# localhost se permite automáticamente en desarrollo.
CLIENT_ORIGIN=http://localhost:5173

# Clerk authentication (real values live in .env.local, written by `clerk init`)
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
